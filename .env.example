# ============================================
# LLM Agent Platform - переменные окружения
# ============================================
# Скопировать в .env и заполнить значения:
#   cp .env.example .env

# --- API ---
APP_PORT=8000
LOG_LEVEL=INFO

# --- Авторизация ---
# Master-токен для полного доступа ко всем эндпоинтам
MASTER_TOKEN=change-me

# --- LLM-провайдер ---
# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# --- Guardrails ---
# Включение prompt injection detection и secret leak masking
GUARDRAILS_ENABLED=true

# --- Circuit Breaker ---
# Порог ошибок для перевода провайдера в Open
CB_ERROR_THRESHOLD=5
# Время (сек) в состоянии Open до перехода в Half-Open
CB_COOLDOWN_SECONDS=30
# Скользящее окно (сек) подсчета ошибок
CB_WINDOW_SECONDS=60

# --- OpenTelemetry ---
# OTLP endpoint для экспорта трассировок (пусто = вывод в console)
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Langfuse ---
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# --- Langfuse internal (docker-compose) ---
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@langfuse-db:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET=change-me-nextauth-secret
LANGFUSE_NEXTAUTH_URL=http://localhost:3001
LANGFUSE_SALT=change-me-salt
