{
  "uid": "llm-platform",
  "title": "LLM Platform",
  "tags": ["llm", "platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Latency by Provider (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p50 {{ provider }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 {{ provider }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Traffic Distribution by Provider",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(llm_requests_total) by (provider)",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Response Codes",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "stacking": { "mode": "normal" }
      },
      "targets": [
        {
          "expr": "sum(increase(llm_requests_total[5m])) by (status_code)",
          "legendFormat": "{{ status_code }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(llm_requests_total[5m])) by (provider)",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cost per Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(llm_request_cost_total[5m])) by (model)",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "TTFT - Time to First Token (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_ttft_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p50 {{ provider }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_ttft_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 {{ provider }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "TPOT - Time per Output Token (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_tpot_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p50 {{ provider }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_tpot_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 {{ provider }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Circuit Breaker Status",
      "type": "stat",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "CLOSED", "color": "green" } }, "type": "value" },
            { "options": { "1": { "text": "OPEN", "color": "red" } }, "type": "value" },
            { "options": { "2": { "text": "HALF_OPEN", "color": "yellow" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "llm_circuit_breaker_state",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    }
  ]
}
