{
  "uid": "llm-platform",
  "title": "LLM Platform",
  "tags": ["llm", "platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Latency by Provider (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p50 {{ provider }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 {{ provider }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Traffic Distribution by Provider",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(llm_requests_total) by (provider)",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Requests by Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*4..|.*5.." },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        {
          "expr": "sum(llm_requests_total) by (status_code)",
          "legendFormat": "HTTP {{ status_code }}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Total Embeddings",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        {
          "expr": "sum(llm_embedding_requests_total) by (status_code)",
          "legendFormat": "Embeddings {{ status_code }}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Total Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "none" },
      "targets": [
        {
          "expr": "sum(llm_request_cost_total)",
          "legendFormat": "Total",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(llm_requests_total[5m])) by (provider)",
          "legendFormat": "chat {{ provider }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(llm_embedding_requests_total[5m])) by (provider)",
          "legendFormat": "embed {{ provider }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "title": "Token Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(llm_tokens_input_total[5m])) by (model)",
          "legendFormat": "input {{ model }}",
          "refId": "A"
        },
        {
          "expr": "sum(increase(llm_tokens_output_total[5m])) by (model)",
          "legendFormat": "output {{ model }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cost per Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(llm_request_cost_total[5m])) by (model)",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Embedding Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_embedding_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p50 {{ provider }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_embedding_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 {{ provider }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Circuit Breaker Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "CLOSED", "color": "green" } }, "type": "value" },
            { "options": { "1": { "text": "OPEN", "color": "red" } }, "type": "value" },
            { "options": { "2": { "text": "HALF_OPEN", "color": "yellow" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "llm_circuit_breaker_state",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    }
  ]
}
